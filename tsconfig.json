{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",          // ここを NodeNext に変更
    "moduleResolution": "NodeNext", // ここも NodeNext に変更
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}